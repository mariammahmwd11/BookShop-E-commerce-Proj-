@using BookSAW.BL.DTO
@model IEnumerable<AuthorDTO>
@{
    ViewData["Title"] = "Authors";
    Layout = "_TemLayout";
    ViewContext.RouteData.Values["area"] = "Admin";

    var searchVal = Context.Request.Query["search"].ToString();
    var filtered = Model ?? Enumerable.Empty<AuthorDTO>();
    if (!string.IsNullOrWhiteSpace(searchVal))
        filtered = filtered.Where(a => a.Name.Contains(searchVal, StringComparison.OrdinalIgnoreCase));
}

<style>
    :root {
        --accent: #C5A992;
        --dark: #2f2f2f;
        --light-bg: #F3F2EC;
        --muted: #757575;
        --border: #E0E0E0;
    }

    .admin-wrapper {
        padding: 48px 40px;
        background-color: var(--light-bg);
        min-height: 80vh;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

        .page-header h2 {
            font-family: 'Prata',serif;
            font-size: 1.8rem;
            color: var(--dark);
            font-weight: 400;
            margin: 0;
        }

    .page-header-meta {
        font-family: 'Raleway',sans-serif;
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 4px;
    }

    .btn-add {
        padding: 10px 22px;
        background: var(--dark);
        color: #fff;
        border: none;
        font-family: 'Raleway',sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: background 0.25s;
        border-radius: 4px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-add:hover {
            background: var(--accent);
            color: #fff;
        }

    .toast {
        position: fixed;
        top: 28px;
        right: 28px;
        z-index: 9999;
        padding: 14px 22px;
        font-family: 'Raleway',sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
        border-radius: 2px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.3s,transform 0.3s;
        pointer-events: none;
    }

        .toast.success {
            background: #2f2f2f;
            border-left: 4px solid #C5A992;
        }

        .toast.error {
            background: #c0392b;
            border-left: 4px solid #922b21;
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

    /* Search bar */
    .filters-bar {
        background: #fff;
        border-radius: 6px;
        padding: 16px 20px;
        margin-bottom: 20px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.05);
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items:center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-family: 'Raleway',sans-serif;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            color: var(--muted);
        }

        .filter-group input[type="text"] {
            padding: 8px 12px;
            border: 1px solid var(--border);
            border-radius: 4px;
            font-family: 'Raleway',sans-serif;
            font-size: 0.85rem;
            color: var(--dark);
            background: #fff;
            outline: none;
            min-width: 220px;
            transition: border-color 0.2s;
            height:38px;
        }

        .filter-group input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(197,169,146,0.15);
        }

    .btn-filter {
        padding: 0 18px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        font-family: 'Raleway', sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        cursor: pointer;
        border-radius: 4px;
        border: 1px solid transparent;
        text-decoration: none;
        transition: all 0.2s;
    }

    /* Apply */
    button.btn-filter {
        background: var(--dark);
        color: #fff;
    }

        button.btn-filter:hover {
            background: var(--accent);
        }

    /* Reset */
    a.btn-filter {
        background: transparent;
        color: var(--muted);
        border-color: var(--border);
    }

        a.btn-filter:hover {
            border-color: var(--dark);
            color: var(--dark);
        }

    /* Table */
    .table-card {
        background: #fff;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        border-radius: 6px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #EDEBE4;
    }

        thead th {
            padding: 13px 16px;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--muted);
            text-align: left;
            white-space: nowrap;
        }

            thead th:first-child {
                padding-left: 24px;
            }

            thead th:last-child {
                padding-right: 24px;
                text-align: right;
            }

    tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
    }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: #fafaf8;
        }

    tbody td {
        padding: 14px 16px;
        font-size: 0.88rem;
        color: var(--dark);
        vertical-align: middle;
    }

        tbody td:first-child {
            padding-left: 24px;
        }

        tbody td:last-child {
            padding-right: 24px;
        }

    /* Author avatar */
    .author-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--border);
        display: block;
    }

    .author-avatar-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #EDEBE4;
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Prata',serif;
        font-size: 1.1rem;
        color: var(--muted);
        font-weight: 400;
    }

    .id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #F3F2EC;
        border: 1px solid #E0E0E0;
        color: var(--muted);
        font-family: 'Raleway',sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        padding: 3px 8px;
        border-radius: 3px;
    }

    .author-name {
        font-family: 'Raleway',sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--dark);
        margin: 0;
    }

    .bio-cell {
        font-family: 'Raleway',sans-serif;
        font-size: 0.83rem;
        color: var(--muted);
        max-width: 340px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .bio-empty {
        font-size: 0.82rem;
        color: #bbb;
        font-style: italic;
    }

    /* Actions */
    .actions {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
        align-items: center;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 13px;
        font-family: 'Raleway',sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        border-radius: 4px;
        white-space: nowrap;
        transition: all 0.18s;
        text-decoration: none;
        border: 1px solid transparent;
        height:38px;
    }

        .btn-action svg {
            width: 11px;
            height: 11px;
            flex-shrink: 0;
        }

    .btn-edit {
        background: transparent;
        border-color: var(--dark);
        color: var(--dark);
    }

        .btn-edit:hover {
            background: var(--dark);
            color: #fff;
        }

    .btn-del {
        background: transparent;
        border-color: #c0392b;
        color: #c0392b;
    }

        .btn-del:hover {
            background: #c0392b;
            color: #fff;
        }

    /* Empty */
    .empty-state {
        text-align: center;
        padding: 72px 20px;
    }

    .empty-state-icon {
        width: 48px;
        height: 48px;
        margin: 0 auto 16px;
        opacity: 0.2;
    }

    .empty-state p {
        color: var(--muted);
        font-size: 0.9rem;
        font-family: 'Raleway',sans-serif;
        margin: 0;
    }

    .empty-state a {
        display: inline-block;
        margin-top: 16px;
        color: var(--dark);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    @@media (max-width:768px) {
        .admin-wrapper {
            padding: 28px 16px;
        }

        .col-bio {
            display: none;
        }
    }

    @@media (max-width:520px) {
        .btn-action span {
            display: none;
        }

        .btn-action {
            padding: 7px 9px;
        }
    }
</style>

<div class="toast" id="toast"></div>

<div class="admin-wrapper">

    <div class="page-header">
        <div>
            <h2>Authors</h2>
            <p class="page-header-meta">@filtered.Count() @(filtered.Count() == 1 ? "author" : "authors") total</p>
        </div>
        <a class="btn-add" href="/Admin/Author/Create">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
            </svg>
            Add Author
        </a>
    </div>

    <!-- Search -->
    <form method="get" action="/Admin/Author/Index">
        <div class="filters-bar">
            <div class="filter-group">
                <label>Search</label>
                <input type="text" name="search" value="@searchVal" placeholder="Author name..." />
            </div>
            <button type="submit" class="btn-filter">Apply</button>
            <a class="btn-filter" href="/Admin/Author/Index">Reset</a>
        </div>
    </form>

    <!-- Table -->
    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th style="width:50px">ID</th>
                    <th style="width:64px">Photo</th>
                    <th style="min-width:160px">Name</th>
                    <th class="col-bio">Bio</th>
                    <th style="text-align:right; width:130px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (filtered.Any())
                {
                    @foreach (var author in filtered)
                    {
                        <tr>
                            <td><span class="id-badge">#@author.Id</span></td>

                            <td>
                                @if (!string.IsNullOrEmpty(author.ImageURl))
                                {
                                    <img class="author-avatar" src="@author.ImageURl" alt="@author.Name"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    <div class="author-avatar-placeholder" style="display:none">
                                        @author.Name.Substring(0, 1).ToUpper()
                                    </div>
                                }
                                else
                                {
                                    <div class="author-avatar-placeholder">
                                        @author.Name.Substring(0, 1).ToUpper()
                                    </div>
                                }
                            </td>

                            <td><p class="author-name">@author.Name</p></td>

                            <td class="col-bio">
                                @if (!string.IsNullOrWhiteSpace(author.Bio))
                                {
                                    <span class="bio-cell">@author.Bio</span>
                                }
                                else
                                {
                                    <span class="bio-empty">No bio provided</span>
                                }
                            </td>

                            <td>
                                <div class="actions">
                                    <a class="btn-action btn-edit" href="/Admin/Author/Edit/@author.Id">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                        <span>Edit</span>
                                    </a>
                                    <form method="post" action="/Admin/Author/Delete/@author.Id" style="margin:0"
                                          onsubmit="return confirmDelete(event, '@Html.Raw(author.Name.Replace("'", "\\'"))')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action btn-del">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#2f2f2f">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <p>No authors found.</p>
                                <a href="/Admin/Author/Create">Add your first author</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(e, name) {
            if (!confirm('Delete "' + name + '"? This cannot be undone.')) {
                e.preventDefault(); return false;
            }
            return true;
        }
        function showToast(msg, type) {
            var t = document.getElementById('toast');
            t.textContent = msg; t.className = 'toast ' + (type || 'success'); t.classList.add('show');
            setTimeout(function(){ t.classList.remove('show'); }, 3500);
        }
        @if (TempData["Success"] != null)
        {
            <text>showToast('@TempData["Success"]','success');</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>showToast('@TempData["Error"]','error');</text>
        }
    </script>
}
