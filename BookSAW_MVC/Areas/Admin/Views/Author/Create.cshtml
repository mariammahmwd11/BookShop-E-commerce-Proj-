@using BookSAW.BL.DTO
@model AuthorDTO
@{
    ViewData["Title"] = "Add Author";
    Layout = "_TemLayout";
    ViewContext.RouteData.Values["area"] = "Admin";
}

<style>
    :root {
        --accent: #C5A992;
        --dark: #2f2f2f;
        --light-bg: #F3F2EC;
        --muted: #757575;
        --border: #E0E0E0;
    }

    .admin-wrapper {
        padding: 48px 40px;
        background-color: var(--light-bg);
        min-height: 80vh;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 28px;
        font-family: 'Raleway',sans-serif;
        font-size: 0.78rem;
        color: var(--muted);
    }

        .breadcrumb a {
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s;
        }

            .breadcrumb a:hover {
                color: var(--dark);
            }

        .breadcrumb svg {
            width: 14px;
            height: 14px;
            opacity: 0.5;
        }

        .breadcrumb span {
            color: var(--dark);
            font-weight: 600;
        }

    .page-header {
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

        .page-header h2 {
            font-family: 'Prata',serif;
            font-size: 1.8rem;
            color: var(--dark);
            font-weight: 400;
            margin: 0 0 6px;
        }

        .page-header p {
            font-family: 'Raleway',sans-serif;
            font-size: 0.82rem;
            color: var(--muted);
            margin: 0;
        }

    .form-card {
        background: #fff;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        border-radius: 6px;
        padding: 40px;
        max-width: 720px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .form-group.full-width {
            grid-column: 1/-1;
        }

        .form-group label {
            font-family: 'Raleway',sans-serif;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            color: var(--muted);
        }

            .form-group label .required {
                color: #c0392b;
                margin-left: 2px;
            }

        .form-group input[type="text"],
        .form-group textarea {
            padding: 11px 14px;
            border: 1px solid var(--border);
            font-family: 'Raleway',sans-serif;
            font-size: 0.9rem;
            color: var(--dark);
            background: #fff;
            border-radius: 4px;
            transition: border-color 0.2s,box-shadow 0.2s;
            outline: none;
            width: 100%;
            box-sizing: border-box;
        }

            .form-group input:focus, .form-group textarea:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(197,169,146,0.15);
            }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
            line-height: 1.6;
        }

    .field-validation-error {
        font-family: 'Raleway',sans-serif;
        font-size: 0.75rem;
        color: #c0392b;
        margin-top: 2px;
    }

    input.input-validation-error, textarea.input-validation-error {
        border-color: #c0392b;
    }

    /* Upload zone — same pattern */
    #Photo {
        display: none;
    }

    .upload-zone {
        border: 2px dashed var(--border);
        border-radius: 50%;
        width: 160px;
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: border-color 0.2s,background 0.2s;
        position: relative;
        background: #fafaf8;
        isolation: isolate;
        user-select: none;
        overflow: hidden;
        margin: 0 auto;
    }

        .upload-zone:hover {
            border-color: var(--accent);
            background: #fff;
        }

        .upload-zone.has-image {
            border-color: var(--accent);
            border-style: solid;
            cursor: default;
        }

    .upload-placeholder {
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

        .upload-placeholder svg {
            width: 32px;
            height: 32px;
            stroke: var(--muted);
            opacity: 0.4;
        }

        .upload-placeholder p {
            font-family: 'Raleway',sans-serif;
            font-size: 0.72rem;
            color: var(--muted);
            margin: 0;
            text-align: center;
            line-height: 1.4;
        }

    #imagePreview {
        display: none;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    .upload-zone.has-image #imagePreview {
        display: block;
    }

    .upload-zone.has-image .upload-placeholder {
        display: none;
    }

    /* Overlay change button appears on hover */
    .change-photo-btn {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(0,0,0,0.55);
        color: #fff;
        border: none;
        font-family: 'Raleway',sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 8px 0;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        gap: 5px;
        opacity: 0;
        transition: opacity 0.2s;
        z-index: 5;
    }

        .change-photo-btn svg {
            width: 10px;
            height: 10px;
            stroke: #fff;
        }

        .change-photo-btn:hover {
            background: rgba(0,0,0,0.75);
        }

    .upload-zone.has-image .change-photo-btn {
        display: inline-flex;
    }

    .upload-zone.has-image:hover .change-photo-btn {
        opacity: 1;
    }

    .upload-hint {
        font-family: 'Raleway',sans-serif;
        font-size: 0.72rem;
        color: #bbb;
        text-align: center;
        margin-top: 10px;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
        position: relative;
        z-index: 10;
    }

    .btn-cancel {
        padding: 11px 22px;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--muted);
        font-family: 'Raleway',sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-cancel:hover {
            border-color: var(--dark);
            color: var(--dark);
        }

    .btn-submit {
        padding: 11px 28px;
        background: var(--dark);
        color: #fff;
        border: none;
        font-family: 'Raleway',sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        border-radius: 4px;
        transition: background 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        position: relative;
        z-index: 10;
    }

        .btn-submit:hover {
            background: var(--accent);
        }

        .btn-submit svg {
            width: 14px;
            height: 14px;
        }

    @@media (max-width:640px) {
        .admin-wrapper {
            padding: 24px 16px;
        }

        .form-card {
            padding: 24px 20px;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="admin-wrapper">

    <div class="breadcrumb">
        <a href="/Admin/Author">Authors</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span>Add Author</span>
    </div>

    <div class="page-header">
        <h2>Add Author</h2>
        <p>Fill in the details to add a new author.</p>
    </div>

    <div class="form-card">
        <form asp-action="Create" asp-controller="Author" asp-area="Admin"
              method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Hidden file input -->
            <input type="file" id="Photo" name="Photo" accept="image/*" onchange="previewImage(this)" />

            <div class="form-grid">

                <!-- Photo — circular avatar upload -->
                <div class="form-group full-width" style="display:flex; flex-direction:column; align-items:center; gap:6px;">
                    <label style="align-self:flex-start">Author Photo</label>
                    <div class="upload-zone" id="uploadZone" onclick="handleZoneClick(event)">
                        <img id="imagePreview" src="" alt="Preview" />
                        <div class="upload-placeholder">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            <p>Upload photo</p>
                        </div>
                        <button type="button" class="change-photo-btn" onclick="openFilePicker(event)">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                            </svg>
                            Change
                        </button>
                    </div>
                    <p class="upload-hint">JPG, PNG, WEBP — max 5MB</p>
                </div>

                <!-- Name -->
                <div class="form-group full-width">
                    <label for="Name">Author Name <span class="required">*</span></label>
                    <input type="text" id="Name" name="Name" value="@Model?.Name"
                           placeholder="e.g. Fyodor Dostoevsky" maxlength="200" />
                    @Html.ValidationMessage("Name")
                </div>

                <!-- Bio -->
                <div class="form-group full-width">
                    <label for="Bio">Bio <span style="color:#bbb;font-weight:400">(optional)</span></label>
                    <textarea id="Bio" name="Bio"
                              placeholder="A brief biography of the author...">@Model?.Bio</textarea>
                </div>

            </div>

            <div class="form-actions">
                <a class="btn-cancel" href="/Admin/Author/Index">Cancel</a>
                <button type="submit" class="btn-submit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Save Author
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        var photoInput = document.getElementById('Photo');
        var uploadZone = document.getElementById('uploadZone');
        var imgPreview = document.getElementById('imagePreview');

        function openFilePicker(event) {
            if (event) event.stopPropagation();
            photoInput.click();
        }
        function handleZoneClick(event) {
            if (uploadZone.classList.contains('has-image')) return;
            openFilePicker(null);
        }
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    imgPreview.src = e.target.result;
                    uploadZone.classList.add('has-image');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
