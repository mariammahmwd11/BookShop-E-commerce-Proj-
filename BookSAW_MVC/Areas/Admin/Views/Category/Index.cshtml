@model IEnumerable<CategoryDTO>
@{
    ViewData["Title"] = "Categories";
    Layout = "_TemLayout";
    ViewContext.RouteData.Values["area"] = "Admin";
}

<style>
    :root {
        --accent: #C5A992;
        --dark: #2f2f2f;
        --light-bg: #F3F2EC;
        --muted: #757575;
        --border: #E0E0E0;
    }

    .admin-wrapper {
        padding: 48px 40px;
        background-color: var(--light-bg);
        min-height: 80vh;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

        .page-header h2 {
            font-family: 'Prata', serif;
            font-size: 1.8rem;
            color: var(--dark);
            font-weight: 400;
            margin: 0;
        }

    .page-header-meta {
        font-family: 'Raleway', sans-serif;
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 4px;
        letter-spacing: 0.03em;
    }

    .btn-add {
        padding: 10px 22px;
        background: var(--dark);
        color: #fff;
        border: none;
        font-family: 'Raleway', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: background 0.25s;
        border-radius: 4px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-add:hover {
            background: var(--accent);
            color: #fff;
        }

    /* Toast */
    .toast {
        position: fixed;
        top: 28px;
        right: 28px;
        z-index: 9999;
        padding: 14px 22px;
        font-family: 'Raleway', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
        border-radius: 2px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
    }

        .toast.success {
            background: #2f2f2f;
            border-left: 4px solid #C5A992;
        }

        .toast.error {
            background: #c0392b;
            border-left: 4px solid #922b21;
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

    /* Table */
    .table-card {
        background: #fff;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        border-radius: 6px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #EDEBE4;
    }

        thead th {
            padding: 13px 20px;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--muted);
            text-align: left;
            white-space: nowrap;
        }

            thead th:first-child {
                padding-left: 24px;
            }

            thead th:last-child {
                padding-right: 24px;
                text-align: right;
            }

    tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
    }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: #fafaf8;
        }

    tbody td {
        padding: 16px 20px;
        font-size: 0.9rem;
        color: var(--dark);
        vertical-align: middle;
    }

        tbody td:first-child {
            padding-left: 24px;
        }

        tbody td:last-child {
            padding-right: 24px;
        }

    .col-id {
        width: 72px;
    }

    .col-photo {
        width: 80px;
    }

    .col-name {
        min-width: 160px;
    }

    .col-desc {
        min-width: 200px;
    }

    .col-actions {
        width: 200px;
        text-align: right;
    }

    .id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #F3F2EC;
        border: 1px solid #E0E0E0;
        color: var(--muted);
        font-family: 'Raleway', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        padding: 4px 9px;
        border-radius: 3px;
        min-width: 36px;
    }

    .cat-thumb {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid var(--border);
        display: block;
    }

    .cat-thumb-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        background: #EDEBE4;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .cat-thumb-placeholder svg {
            width: 20px;
            height: 20px;
            opacity: 0.35;
        }

    .cat-name {
        font-family: 'Raleway', sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--dark);
        margin: 0;
    }

    .cat-desc {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.5;
        max-width: 340px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cat-desc-empty {
        font-size: 0.82rem;
        color: #bbb;
        font-style: italic;
    }

    .actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        align-items: center;
    }

    .btn-edit, .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        font-family: 'Raleway', sans-serif;
        font-size: 0.73rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        cursor: pointer;
        border-radius: 4px;
        white-space: nowrap;
        transition: all 0.18s;
        text-decoration: none;
    }

    .btn-edit {
        background: transparent;
        border: 1px solid var(--dark);
        color: var(--dark);
    }

        .btn-edit:hover {
            background: var(--dark);
            color: #fff;
            transform: translateY(-1px);
        }

    .btn-delete {
        background: transparent;
        border: 1px solid #c0392b;
        color: #c0392b;
    }

        .btn-delete:hover {
            background: #c0392b;
            color: #fff;
            transform: translateY(-1px);
        }

        .btn-edit svg, .btn-delete svg {
            width: 12px;
            height: 12px;
            flex-shrink: 0;
        }

    .empty-state {
        text-align: center;
        padding: 72px 20px;
    }

    .empty-state-icon {
        width: 48px;
        height: 48px;
        margin: 0 auto 16px;
        opacity: 0.2;
    }

    .empty-state p {
        color: var(--muted);
        font-size: 0.9rem;
        font-family: 'Raleway', sans-serif;
        margin: 0;
    }

    .empty-state a {
        display: inline-block;
        margin-top: 16px;
        color: var(--dark);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-decoration: underline;
        text-underline-offset: 3px;
        cursor: pointer;
    }

    @@media (max-width: 768px) {
        .admin-wrapper {
            padding: 28px 16px;
        }

        .col-desc {
            display: none;
        }

        .btn-edit span, .btn-delete span {
            display: none;
        }

        .btn-edit, .btn-delete {
            padding: 8px 10px;
        }
    }

    @@media (max-width: 520px) {
        .page-header h2 {
            font-size: 1.3rem;
        }

        .col-id {
            display: none;
        }
    }
</style>

<div class="toast success" id="toast"></div>

<div class="admin-wrapper">
    <div class="page-header">
        <div>
            <h2>Categories</h2>
            @if (Model != null)
            {
                <p class="page-header-meta">@Model.Count() @(Model.Count() == 1 ? "category" : "categories") total</p>
            }
        </div>
        <a class="btn-add" href="/Admin/Category/Create">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
            </svg>
            Add Category
        </a>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-photo">Photo</th>
                    <th class="col-name">Category Name</th>
                    <th class="col-desc">Description</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td class="col-id">
                                <span class="id-badge">#@cat.CategoryId</span>
                            </td>

                            <td class="col-photo">
                                @if (!string.IsNullOrEmpty(cat.ImageUrl))
                                {
                                    <img class="cat-thumb"
                                         src="@cat.ImageUrl"
                                         alt="@cat.Name"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    <div class="cat-thumb-placeholder" style="display:none">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#999">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                }
                                else
                                {
                                    <div class="cat-thumb-placeholder">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#999">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                }
                            </td>

                            <td class="col-name">
                                <p class="cat-name">@cat.Name</p>
                            </td>

                            <td class="col-desc">
                                @if (!string.IsNullOrWhiteSpace(cat.Description))
                                {
                                    <span class="cat-desc">@cat.Description</span>
                                }
                                else
                                {
                                    <span class="cat-desc-empty">No description</span>
                                }
                            </td>

                            <td class="col-actions">
                                <div class="actions">
                                    <a class="btn-edit" href="/Admin/Category/Edit/@cat.CategoryId">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                        <span>Edit</span>
                                    </a>
                                    <form method="post"
                                          action="/Admin/Category/Delete/@cat.CategoryId"
                                          style="margin:0"
                                          onsubmit="return confirmDelete(event, '@cat.Name')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-delete">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#2f2f2f">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                </svg>
                                <p>No categories yet.</p>
                                <a href="/Admin/Category/Create">Add your first category</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(e, name) {
            if (!confirm('Delete "' + name + '"? This action cannot be undone.')) {
                e.preventDefault();
                return false;
            }
            return true;
        }

        function showToast(message, type) {
            var t = document.getElementById('toast');
            t.textContent = message;
            t.className = 'toast ' + (type || 'success');
            t.classList.add('show');
            setTimeout(function () { t.classList.remove('show'); }, 3500);
        }

        @if (TempData["SuccessMessage"] != null)
        {
                <text>showToast('@TempData["SuccessMessage"]', 'success');</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                <text>showToast('@TempData["ErrorMessage"]', 'error');</text>
        }
    </script>
}
