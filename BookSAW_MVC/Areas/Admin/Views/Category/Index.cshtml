@model IEnumerable<CategoryDTO>
@{
    ViewData["Title"] = "Categories";
    Layout = "_TemLayout";
    ViewContext.RouteData.Values["area"] = "Admin";
}

<style>
    :root {
        --accent: #C5A992;
        --dark: #2f2f2f;
        --light-bg: #F3F2EC;
        --muted: #757575;
        --border: #E0E0E0;
        --error: #c0392b;
    }

    .admin-page-wrapper {
        padding: 48px 40px;
        background-color: var(--light-bg);
        min-height: 80vh;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

        .page-header h2 {
            font-family: 'Prata', serif;
            font-size: 1.8rem;
            color: var(--dark);
            font-weight: 400;
            margin: 0;
        }

    .btn-add {
        padding: 12px 28px;
        background: var(--dark);
        color: #fff;
        border: none;
        font-family: 'Raleway', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: background 0.25s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-add:hover {
            background: var(--accent);
            color: #fff;
        }

    .table-card {
        background: #fff;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #EDEBE4;
    }

        thead th {
            padding: 14px 20px;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--dark);
            text-align: left;
        }

    tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
    }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: #fafaf8;
        }

    tbody td {
        padding: 16px 20px;
        font-size: 0.9rem;
        color: var(--dark);
        vertical-align: middle;
    }

    .td-id {
        color: var(--muted);
        font-size: 0.82rem;
        width: 60px;
    }

    .actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .btn-edit {
        padding: 7px 18px;
        background: transparent;
        border: 1px solid var(--dark);
        color: var(--dark);
        font-family: 'Raleway', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-edit:hover {
            background: var(--dark);
            color: #fff;
        }

    .btn-delete {
        padding: 7px 18px;
        background: transparent;
        border: 1px solid #c0392b;
        color: #c0392b;
        font-family: 'Raleway', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-delete:hover {
            background: #c0392b;
            color: #fff;
        }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
        font-size: 0.9rem;
    }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-card {
        background: #fff;
        width: 100%;
        max-width: 480px;
        padding: 40px;
        box-shadow: 0 16px 48px rgba(0,0,0,0.15);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

        .modal-header h3 {
            font-family: 'Prata', serif;
            font-size: 1.4rem;
            color: var(--dark);
            font-weight: 400;
            margin: 0;
        }

    .modal-close {
        background: none;
        border: none;
        font-size: 1.4rem;
        color: var(--muted);
        cursor: pointer;
        line-height: 1;
        padding: 0;
    }

        .modal-close:hover {
            color: var(--dark);
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--dark);
            margin-bottom: 8px;
        }

        .form-group input[type="text"] {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid var(--border);
            background: #fafaf8;
            font-family: 'Raleway', sans-serif;
            font-size: 0.9rem;
            color: var(--dark);
            border-radius: 0;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input:focus {
            border-color: var(--accent);
            background: #fff;
        }

    .modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px;
    }

    .btn-submit {
        flex: 1;
        padding: 13px;
        background: var(--dark);
        color: #fff;
        border: none;
        font-family: 'Raleway', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: background 0.25s;
    }

        .btn-submit:hover {
            background: var(--accent);
        }

    .btn-cancel {
        flex: 1;
        padding: 13px;
        background: transparent;
        color: var(--dark);
        border: 1px solid var(--border);
        font-family: 'Raleway', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            border-color: var(--dark);
        }

    @@media (max-width: 768px) {
        .admin-page-wrapper {
            padding: 28px 16px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        thead th:first-child, tbody td:first-child {
            display: none;
        }
    }
</style>

<div class="admin-page-wrapper">

    <div class="page-header">
        <h2>Categories</h2>
        <button class="btn-add" onclick="openModal()">+ Add Category</button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background:#e9f7ef;border-left:3px solid #27ae60;padding:12px 16px;margin-bottom:20px;font-size:0.85rem;color:#1e8449;">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div style="background:#fdf0ef;border-left:3px solid #c0392b;padding:12px 16px;margin-bottom:20px;font-size:0.85rem;color:#c0392b;">
            @TempData["Error"]
        </div>
    }

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th class="td-id">#</th>
                    <th>Category Name</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td class="td-id">@cat.CategoryId</td>
                            <td>@cat.Name</td>
                            <td>
                                <div class="actions">
                                    <a class="btn-edit"
                                       href="/Admin/Category/Edit/@cat.CategoryId">
                                        Edit
                                    </a>
                                    <form method="post"
                                          action="/Admin/Category/Delete/@cat.CategoryId"
                                          onsubmit="return confirm('Delete @cat.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-delete">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3">
                            <div class="empty-state">No categories found. Add your first one!</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Category Modal -->
<div class="modal-overlay" id="addModal">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Add Category</h3>
            <button class="modal-close" onclick="closeModal()">&#x2715;</button>
        </div>
        <form method="post" action="/Admin/Category/Create">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="Name">Category Name</label>
                <input type="text" id="Name" name="Name"
                       placeholder="e.g. Science Fiction" required />
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button type="submit" class="btn-submit">Add Category</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal() {
            document.getElementById('addModal').classList.add('active');
        }
        function closeModal() {
            document.getElementById('addModal').classList.remove('active');
        }
        document.getElementById('addModal').addEventListener('click', function (e) {
            if (e.target === this) closeModal();
        });
    </script>
}