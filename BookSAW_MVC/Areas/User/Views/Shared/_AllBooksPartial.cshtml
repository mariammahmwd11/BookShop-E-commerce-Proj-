@using BookSAW.BL.DTO
@using BookSAW_MVC.Areas.User.ViewModels
@model HomeVM
<style>
    .product-item figure.product-style {
        height: 280px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9f9f9;
        padding: 10px 20px;
    }

        .product-item figure.product-style img.product-item {
            width: 100%;
            height: 100%;
            object-fit: contain;
            max-width: 85%;
        }

    .no-cover {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    /* Price styling */
    .item-price {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .prev-price {
        text-decoration: line-through;
        color: #999;
        font-size: 0.9em;
    }

    .current-price {
        color: #e74c3c;
        font-weight: bold;
    }
</style>
<section id="popular-books" class="bookshelf py-5 my-5">
    <div class="container">
        <div class="row">
            <div class="col-md-12">

                <div class="section-header align-center reveal-on-scroll">
                    <div class="title"><span>Some quality items</span></div>
                    <h2 class="section-title">Popular Books</h2>
                </div>

                <!-- Tab headers: All + one per category -->
                <ul class="tabs">
                    <li data-tab-target="#tab-all" class="active tab">All</li>
                    @foreach (var cat in Model.Categories)
                    {
                        <li data-tab-target="#tab-cat-@cat.CategoryId" class="tab">@cat.Name</li>
                    }
                </ul>

                <div class="tab-content">

                    <!-- ALL BOOKS tab -->
                    <div id="tab-all" data-tab-content class="active">
                        <div class="row">
                            @foreach (var book in Model.AllBooks)
                            {
                                <div class="col-md-3 reveal-on-scroll delay-@((Model.AllBooks.ToList().IndexOf(book) % 4) + 1)">
                                    <div class="product-item">
                                        <figure class="product-style">
                                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                                            {
                                                <img src="@book.ImageUrl" alt="@book.Name" class="product-item" loading="lazy" />
                                            }
                                            else
                                            {
                                                <div class="no-cover">
                                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                                    </svg>
                                                    <span>No Cover</span>
                                                </div>
                                            }

                                            <form method="post" action="/Cart/Add" style="display:contents">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="bookId" value="@book.BookID" />
                                                <button type="submit" class="add-to-cart" data-product-tile="add-to-cart">Add to Cart</button>
                                            </form>
                                        </figure>
                                        <figcaption>
                                            <h3><a href="/Books/Details/@book.BookID" style="text-decoration:none;color:inherit;">@book.Name</a></h3>
                                            <span>@book.AuthorName</span>
                                            <div class="item-price">
                                                @{
                                                    var finalPrice = book.Price * (1 - book.DiscountPercent / 100m);
                                                }


                                                @if (book.DiscountPercent > 0)
                                                {
                                                    <span class="prev-price">$@book.Price.ToString("0.00")</span>

                                                    @("$" + finalPrice?.ToString("0.00"))
                                                }
                                                else
                                                {
                                                    <span>$@book.Price.ToString("0.00")</span>
                                                }

                                            </div>
                                        </figcaption>
                                    </div>
                                </div>
                            }
                            @if (!Model.AllBooks.Any())
                            {
                                <div class="col-12 text-center py-5" style="color:#999;font-style:italic;">No books found.</div>
                            }
                        </div>
                    </div>

                    <!-- PER-CATEGORY tabs -->
                    @foreach (var cat in Model.Categories)
                    {
                        var catBooks = Model.AllBooks.Where(b => b.CategoryId == cat.CategoryId);
                        <div id="tab-cat-@cat.CategoryId" data-tab-content>
                            <div class="row">
                                @foreach (var book in catBooks)
                                {
                                    <div class="col-md-3">
                                        <div class="product-item">
                                            <figure class="product-style">
                                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                                {
                                                    <img src="@book.ImageUrl" alt="@book.Name" class="product-item" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div class="no-cover">
                                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                                        </svg>
                                                        <span>No Cover</span>
                                                    </div>
                                                }

                                                <form method="post" action="/Cart/Add" style="display:contents">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="bookId" value="@book.BookID" />
                                                    <button type="submit" class="add-to-cart" data-product-tile="add-to-cart">Add to Cart</button>
                                                </form>
                                            </figure>
                                            <figcaption>
                                                <h3><a href="/Books/Details/@book.BookID" style="text-decoration:none;color:inherit;">@book.Name</a></h3>
                                                <span>@book.AuthorName</span>
                                                <div class="item-price">
                                                    @if (book.DiscountPercent > 0)
                                                    {
                                                        <span class="prev-price">$@book.Price.ToString("0.00")</span>
                                                        @("$" + (book.Price * (1 - book.DiscountPercent / 100m)).ToString())
                                                    }
                                                    else
                                                    {
                                                        @("$" + book.Price.ToString("0.00"))
                                                    }
                                                </div>
                                            </figcaption>
                                        </div>
                                    </div>
                                }
                                @if (!catBooks.Any())
                                {
                                    <div class="col-12 text-center py-5" style="color:#999;font-style:italic;">No books in this category yet.</div>
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</section>
<!-- ════════════════════════════════════
     JS — Sticky nav + Scroll reveal
════════════════════════════════════ -->
<script>
    /* Sticky nav */
    (function() {
        var header = document.querySelector('header, .site-header, nav.navbar');
        if (!header) return;
        window.addEventListener('scroll', function() {
            header.classList.toggle('nav-scrolled', window.scrollY > 60);
        }, { passive: true });
    })();

    /* Scroll reveal via Intersection Observer */
    (function() {
        var els = document.querySelectorAll('.reveal-on-scroll');
        if (!els.length) return;
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
                if (e.isIntersecting) {
                    e.target.classList.add('is-visible');
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.12, rootMargin: '0px 0px -30px 0px' });
        els.forEach(function(el) { observer.observe(el); });
    })();

    /* Add-to-Cart feedback */
    document.querySelectorAll('.add-to-cart').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            var orig = btn.textContent;
            btn.textContent = '✓ Added';
            btn.style.background = '#4a7c59';
            setTimeout(function() {
                btn.textContent = orig;
                btn.style.background = '';
            }, 1800);
        });
    });
</script>
