@using BookSAW.BL.DTO
@using BookSAW_MVC.Areas.User.ViewModels
@model HomeVM

<style>
    .product-item figure.product-style {
        height: 280px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9f9f9;
        padding: 10px 20px;
    }

        .product-item figure.product-style img.product-item {
            width: 100%;
            height: 100%;
            object-fit: contain;
            max-width: 85%;
        }

    .no-cover {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    /* ── Price styling ── */
    .item-price {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .prev-price {
        text-decoration: line-through;
        color: #999;
        font-size: 0.9em;
    }

    .current-price {
        color: #e74c3c;
        font-weight: bold;
    }

    /* ══════════════════════════════════════════════
               ADD TO CART BUTTON — two states
            ══════════════════════════════════════════════ */

    button.add-to-cart {
        transition: background 0.25s ease, transform 0.15s ease;
        position: relative;
        overflow: hidden;
    }

        button.add-to-cart.in-cart {
            background: #4a7c59 !important;
            color: #fff !important;
            cursor: default;
            pointer-events: none;
            opacity: 0.92;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

            button.add-to-cart.in-cart::before {
                content: '✓';
                font-size: 0.95em;
                font-weight: 700;
            }

        /* Loading Spinner inside button */
        button.add-to-cart .spinner {
            display: none;
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 0.8s linear infinite;
            margin-right: 6px;
        }

        button.add-to-cart.loading .btn-text {
            display: none;
        }

        button.add-to-cart.loading .spinner {
            display: inline-block;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .go-to-cart-link {
        display: none;
        text-align: center;
        margin-top: 6px;
        font-size: 0.75rem;
    }

        .go-to-cart-link a {
            color: #4a7c59;
            text-decoration: underline;
            text-underline-offset: 2px;
            font-weight: 600;
            transition: color 0.2s;
        }

            .go-to-cart-link a:hover {
                color: #2e5c3a;
            }

    button.add-to-cart.in-cart ~ .go-to-cart-link {
        display: block;
    }

    /* 🍞 Toast Notification */
    .cart-toast {
        position: fixed;
        top: 24px;
        right: 24px;
        background: #fff;
        color: #2f2f2f;
        padding: 14px 20px;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(47,47,47,0.15);
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        font-weight: 500;
        z-index: 9999;
        animation: slideInToast 0.3s ease;
        border-left: 4px solid #4a7c59;
        max-width: 320px;
    }

        .cart-toast.error {
            border-left-color: #c0392b;
        }

            .cart-toast.error svg {
                color: #c0392b;
            }

        .cart-toast.success svg {
            color: #27ae60;
        }

    @@keyframes slideInToast {
        from {
            opacity: 0;
            transform: translateX(100px) translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateX(0) translateY(0);
        }
    }
</style>

<section id="popular-books" class="bookshelf py-5 my-5">
    <div class="container">
        <div class="row">
            <div class="col-md-12">

                <div class="section-header align-center reveal-on-scroll">
                    <div class="title"><span>Some quality items</span></div>
                    <h2 class="section-title">Popular Books</h2>
                </div>

                <ul class="tabs">
                    <li data-tab-target="#tab-all" class="active tab">All</li>
                    @foreach (var cat in Model.Categories)
                    {
                        <li data-tab-target="#tab-cat-@cat.CategoryId" class="tab">@cat.Name</li>
                    }
                </ul>

                <div class="tab-content">

                    <!-- ══════ ALL BOOKS tab ══════ -->
                    <div id="tab-all" data-tab-content class="active">
                        <div class="row">
                            @foreach (var book in Model.AllBooks)
                            {
                                var inCart = Model.CartBookIds.Contains(book.BookID);
                                var btnClass = inCart ? "add-to-cart in-cart" : "add-to-cart";
                                var btnText = inCart ? "Added to Cart" : "Add to Cart";

                                <div class="col-md-3 reveal-on-scroll delay-@((Model.AllBooks.ToList().IndexOf(book) % 4) + 1)">
                                    <div class="product-item">
                                        <figure class="product-style">

                                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                                            {
                                                <img src="@book.ImageUrl" alt="@book.Name" class="product-item" loading="lazy" />
                                            }
                                            else
                                            {
                                                <div class="no-cover">
                                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                                              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                                    </svg>
                                                    <span>No Cover</span>
                                                </div>
                                            }

                                            @* ── Add to Cart Section ── *@
                                            <div class="add-to-cart-wrapper" data-book-id="@book.BookID">
                                                @if (!inCart)
                                                {
                                                    <button type="button"
                                                            class="@btnClass"
                                                            onclick="handleAddToCart('@book.BookID', this)">
                                                        <span class="spinner"></span>
                                                        <span class="btn-text">@btnText</span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="@btnClass" disabled>
                                                        @btnText
                                                    </button>
                                                }

                                                
                                            </div>

                                        </figure>
                                        <figcaption>
                                            <h3>
                                                <a asp-area="User" asp-controller="Book" asp-action="Index" style="text-decoration:none;color:inherit;">
                                                    @book.Name
                                                </a>
                                            </h3>
                                            <span>@book.AuthorName</span>
                                            <div class="item-price">
                                                @{
                                                    var finalPrice = book.Price * (1 - book.DiscountPercent / 100m);
                                                }
                                                @if (book.DiscountPercent > 0)
                                                {
                                                    <span class="prev-price">$@book.Price.ToString("0.00")</span>
                                                    <span>$@finalPrice?.ToString("0.00")</span>
                                                }
                                                else
                                                {
                                                    <span>$@book.Price.ToString("0.00")</span>
                                                }
                                            </div>
                                        </figcaption>
                                    </div>
                                </div>
                            }

                            @if (!Model.AllBooks.Any())
                            {
                                <div class="col-12 text-center py-5" style="color:#999;font-style:italic;">
                                    No books found.
                                </div>
                            }
                        </div>
                    </div>

                    @* ══════ Category Tabs ══════ *@
                    @foreach (var cat in Model.Categories)
                    {
                        var catBooks = Model.AllBooks.Where(b => b.CategoryId == cat.CategoryId);

                        <div id="tab-cat-@cat.CategoryId" data-tab-content>
                            <div class="row">
                                @foreach (var book in catBooks)
                                {
                                    var inCart2 = Model.CartBookIds.Contains(book.BookID);
                                    var btnClass2 = inCart2 ? "add-to-cart in-cart" : "add-to-cart";
                                    var btnText2 = inCart2 ? "Added to Cart" : "Add to Cart";

                                    <div class="col-md-3">
                                        <div class="product-item">
                                            <figure class="product-style">

                                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                                {
                                                    <img src="@book.ImageUrl" alt="@book.Name" class="product-item" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div class="no-cover">
                                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                                                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                                        </svg>
                                                        <span>No Cover</span>
                                                    </div>
                                                }

                                                @* ── Add to Cart Section (Repeated for tabs) ── *@
                                                <div class="add-to-cart-wrapper" data-book-id="@book.BookID">
                                                    @if (!inCart2)
                                                    {
                                                        <button type="button"
                                                                class="@btnClass2"
                                                                onclick="handleAddToCart('@book.BookID', this)">
                                                            <span class="spinner"></span>
                                                            <span class="btn-text">@btnText2</span>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="@btnClass2" disabled>
                                                            @btnText2
                                                        </button>
                                                    }

                                                    
                                                </div>

                                            </figure>
                                            <figcaption>
                                                <h3>
                                                    <a asp-area="User" asp-controller="Book" asp-action="Index" style="text-decoration:none;color:inherit;">
                                                        @book.Name
                                                    </a>
                                                </h3>
                                                <span>@book.AuthorName</span>
                                                <div class="item-price">
                                                    @{
                                                        var finalPrice = book.Price * (1 - book.DiscountPercent / 100m);
                                                    }
                                                    @if (book.DiscountPercent > 0)
                                                    {
                                                        <span class="prev-price">$@book.Price.ToString("0.00")</span>
                                                        <span>$@finalPrice?.ToString("0.00")</span>
                                                    }
                                                    else
                                                    {
                                                        <span>$@book.Price.ToString("0.00")</span>
                                                    }
                                                </div>
                                            </figcaption>
                                        </div>
                                    </div>
                                }

                                @if (!catBooks.Any())
                                {
                                    <div class="col-12 text-center py-5" style="color:#999;font-style:italic;">
                                        No books in this category yet.
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ════════════════════════════════════
     JS - AJAX Handler
════════════════════════════════════ -->
<script>
    /* Sticky nav & Scroll reveal */
    (function () {
        var header = document.querySelector('header, .site-header, nav.navbar');
        if (!header) return;
        window.addEventListener('scroll', function () {
            header.classList.toggle('nav-scrolled', window.scrollY > 60);
        }, { passive: true });
    })();

    (function () {
        var els = document.querySelectorAll('.reveal-on-scroll');
        if (!els.length) return;
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
                if (e.isIntersecting) {
                    e.target.classList.add('is-visible');
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.12, rootMargin: '0px 0px -30px 0px' });
        els.forEach(function (el) { observer.observe(el); });
    })();

    /* ════════════════════════════════════
       AJAX Add to Cart Handler
       ════════════════════════════════════ */
    async function handleAddToCart(bookId, btn) {
        if (btn.disabled || btn.classList.contains('in-cart') || btn.classList.contains('loading')) return;

        const btnText = btn.querySelector('.btn-text');
        const originalText = btnText ? btnText.textContent : '';

        try {
            btn.disabled = true;
            btn.classList.add('loading');

            // 1. جلب التوكن من الـ form المخفي
            const tokenInput = document.querySelector('#__AjaxTokenForm input[name="__RequestVerificationToken"]');
            if (!tokenInput) {
                console.error('Anti-Forgery Token not found!');
                showToast('⚠️ خطأ في التحقق الأمني. يرجى تحديث الصفحة.', 'error');
                btn.disabled = false;
                btn.classList.remove('loading');
                return;
            }
            const token = tokenInput.value;

            // 2. إرسال الطلب مع التوكن في الهيدر
               const response = await fetch('/User/Cart/AddToCart', {
        method: 'POST',
        credentials: 'include', 
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': token
        },
        body: `bookId=${encodeURIComponent(bookId)}`
    });

            // 3. كشف لو حصل ريديركت للوجن
            const contentType = response.headers.get('content-type') || '';
            const isRedirectToLogin = response.url.includes('/Login') || !contentType.includes('application/json');

            if (isRedirectToLogin) {
                window.location.href = '/User/Account/Login?returnUrl=' + encodeURIComponent(window.location.href);
                return;
            }

            // 4. معالجة الاستجابة
            if (response.ok) {
                const result = await response.json();

                if (!result.isAuthenticated) {
                    window.location.href = result.loginUrl || '/User/Account/Login';
                    return;
                }

                if (result.success) {
                    btn.classList.remove('loading');
                    btn.classList.add('in-cart');
                    btn.disabled = true;
                    btn.innerHTML = 'Added to Cart';
                    showToast('✅ Added to cart successfully!', 'success');
                    refreshCartCount(); // ✅ دلوقتي هتشتغل
                } else {
                    throw new Error(result.message || 'Server error');
                }
            } else {
                throw new Error('HTTP ' + response.status);
            }

        } catch (error) {
            console.error('Add to cart error:', error);
            btn.classList.remove('loading');
            btn.disabled = false;
            if (btnText) btnText.textContent = originalText;
            showToast('⚠️ ' + (error.message || 'Could not add to cart.'), 'error');
        }
    }

    /* 🍞 Toast Notification Helper */
    function showToast(message, type = 'success') {
        document.querySelectorAll('.cart-toast').forEach(t => t.remove());

        const toast = document.createElement('div');
        toast.className = `cart-toast ${type}`;

        const icon = type === 'success'
            ? `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
            : `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;

        toast.innerHTML = `${icon}<span>${message}</span>`;
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-10px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    /* 🔄 Update Cart Count - Incremental */
    function updateCartCount(increment = 1) {
        const selectors = ['#cartCountPill', '.cart-count-pill', '[id*="cartCount"]'];

        for (const selector of selectors) {
            const el = document.querySelector(selector);
            if (el) {
                const text = el.textContent;
                const match = text.match(/(\d+)/);
                if (match) {
                    const current = parseInt(match[1]);
                    el.textContent = text.replace(/\d+/, current + increment);
                }
                break;
            }
        }
    } 

    /* 🔄 Refresh Cart Count from Server */
    function refreshCartCount() {
        fetch('/User/Cart/GetCount')
            .then(res => res.json())
            .then(data => {
                const el = document.getElementById("cartCount");
                if (el) {
                    el.innerText = data.count;
                }
            })
            .catch(err => console.error('Failed to refresh cart count:', err));
    }
</script>